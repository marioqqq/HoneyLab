# NFS setup
IP=xx.xx.xx.xx
DOWNLOADS=:/path/to/downloads
MOVIES=:/path/to/movies
MOVIES_CZSK=:/path/to/movies-czsk # remove if you don't have a czech/slovak movies share
MUSIC=:/path/to/music
WATCH=:/path/to/watch

# Transmission
CONFIG=vpn.config
PROVIDER=provider
USERNAME=user
PASSWORD=pass
LOCAL_NETWORK=xx.xx.xx.0/yy

# Watchtower
GOTIFY_URL=https://gotify.url
GOTIFY_TOKEN=secrettoken